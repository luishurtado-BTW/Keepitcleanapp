# KeepitClean Firebase Configuration
# Copia este archivo como .env en la raíz del proyecto y reemplaza con tus credenciales reales.
# Si estos valores quedan vacíos o con los marcadores de posición predeterminados, 
# la aplicación activará automáticamente el modo Mock (LocalStorage) para pruebas.

VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
